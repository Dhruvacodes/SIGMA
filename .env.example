# LLM Provider: "groq" or "anthropic"
LLM_PROVIDER=groq

# API Keys
GROQ_API_KEY=gsk_...
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...

# ChromaDB Cloud
USE_CHROMA_CLOUD=true
CHROMA_API_KEY=ck-...
CHROMA_TENANT=your-tenant-id
CHROMA_DATABASE=SIGMA

# Local fallback
CHROMA_PERSIST_DIR=./chroma_db
